# Copy this file to .env and fill in your values for local development
# NEVER commit .env to git

# Server
PORT=8080

# CORS: comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173

# JWT Secret (use a strong base64-encoded 512-bit key in production)
JWT_SECRET=Mjg0YjVkNmQ4NDVlYzMyZTNkOWFjYTcwNzEwNmUxNGE3OWUwODlkODNiNzU5YWIzYjhiMDQ1OTBiNWRjY2JhMA==
JWT_EXPIRATION=86400000

# OpenAI API Key (set to "mock" to use simulated AI responses)
OPENAI_KEY=mock
